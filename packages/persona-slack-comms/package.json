{
  "name": "@agentworkforce/persona-slack-comms",
  "version": "0.1.2",
  "description": "AgentWorkforce slack-comms persona pack — comms-only Slack liaison for a multi-agent engineering team: relays human Slack messages to the agent team and surfaces milestones, decisions, blockers, and security incidents back to humans via relayfile writeback. Install with `agentworkforce install`.",
  "type": "module",
  "main": "index.js",
  "types": "index.d.ts",
  "agentworkforce": {
    "personas": "personas"
  },
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js",
      "default": "./index.js"
    },
    "./persona.json": "./personas/slack-comms.json",
    "./personas/slack-comms.json": "./personas/slack-comms.json",
    "./package.json": "./package.json"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "personas"
  ],
  "scripts": {
    "test": "node --test test/persona.test.mjs"
  },
  "keywords": [
    "agentworkforce",
    "persona",
    "slack",
    "relayfile",
    "comms"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AgentWorkforce/workforce",
    "directory": "packages/persona-slack-comms"
  }
}
