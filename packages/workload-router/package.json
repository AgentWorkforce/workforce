{
  "name": "@agentworkforce/workload-router",
  "version": "0.3.0",
  "private": false,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "agent-workforce": "dist/cli.js"
  },
  "files": [
    "dist",
    "routing-profiles",
    "README.md",
    "package.json"
  ],
  "dependencies": {
    "@agent-relay/sdk": "^4.0.5"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AgentWorkforce/workforce"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "generate:personas": "node ./scripts/generate-personas.mjs",
    "build": "npm run generate:personas && tsc -p tsconfig.json && chmod +x dist/cli.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run generate:personas && tsc -p tsconfig.json && node --test dist/index.test.js",
    "lint": "npm run generate:personas && tsc -p tsconfig.json --noEmit"
  }
}
