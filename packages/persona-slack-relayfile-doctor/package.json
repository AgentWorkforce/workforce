      "types": "./index.d.ts",
      "import": "./index.js",
      "default": "./index.js"
    },
    "./persona.json": "./personas/slack-relayfile-doctor.json",
    "./personas/slack-relayfile-doctor.json": "./personas/slack-relayfile-doctor.json",
    "./package.json": "./package.json"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "personas"
  ],
  "scripts": {
    "test": "node --test test/persona.test.mjs"
  },
  "keywords": [
    "agentworkforce",
    "persona",
    "slack",
    "relayfile",
    "cloud",
    "debugging",
    "writeback",
    "sync"
  ],
