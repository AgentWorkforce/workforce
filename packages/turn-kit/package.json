{
  "name": "@agentworkforce/turn-kit",
  "version": "4.1.34",
  "private": false,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./assistant": {
      "types": "./dist/assistant.d.ts",
      "default": "./dist/assistant.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "package.json"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/AgentWorkforce/workforce",
    "directory": "packages/turn-kit"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsc -p tsconfig.json && node --test dist/*.test.js",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@agentworkforce/persona-kit": "workspace:*",
    "@agentworkforce/runtime": "workspace:*"
  },
  "peerDependencies": {
    "@agent-assistant/turn-context": "^0.4.35"
  },
  "peerDependenciesMeta": {
    "@agent-assistant/turn-context": {
      "optional": true
    }
  },
  "devDependencies": {
    "@agent-assistant/turn-context": "^0.4.35"
  }
}
