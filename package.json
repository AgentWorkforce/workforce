{
  "name": "workforce",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.17.1",
  "devDependencies": {
    "@agent-relay/sdk": "^4.0.5",
    "@types/node": "^22.18.0",
    "typescript": "^5.9.2"
  },
  "scripts": {
    "build": "corepack pnpm -r build",
    "typecheck": "corepack pnpm -r typecheck && corepack pnpm run typecheck:examples",
    "typecheck:examples": "tsc -p examples/tsconfig.json --noEmit",
    "test": "corepack pnpm -r test",
    "lint": "corepack pnpm -r lint",
    "check": "corepack pnpm run lint && corepack pnpm run typecheck && corepack pnpm run test"
  }
}
